{
  "name": "aimplify-api",
  "version": "1.0.0",
  "description": "AIMPLIFY Backend API - Node.js + Express",
  "main": "src/index.js",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "predev": "node scripts/ensureBetterSqlite.js",
    "prestart": "node scripts/ensureBetterSqlite.js",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "rebuild-sqlite": "npm rebuild better-sqlite3",
    "fresh-sqlite-addon": "node scripts/freshBetterSqlite.js",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "restart:pm2": "pm2 restart ecosystem.config.js",
    "stop:pm2": "pm2 stop ecosystem.config.js",
    "logs:pm2": "pm2 logs ecosystem.config.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.4.0",
    "multer": "^1.4.5-lts.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pm2": "^5.3.0"
  }
}
